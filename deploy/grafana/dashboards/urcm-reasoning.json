{
  "title": "URCM Reasoning Performance",
  "uid": "urcm-reasoning",
  "tags": ["urcm", "production", "reasoning"],
  "timezone": "utc",
  "panels": [
    {
      "id": 1,
      "title": "P99 Latency (ms)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(urcm_reason_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          }
        }
      },
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 2,
      "title": "Avg Convergence Steps",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(urcm_mu_step_total[5m]) / rate(urcm_process_total[5m])",
          "legendFormat": "Avg Steps"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 3,
      "title": "Convergence Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(urcm_reason_counts_converged[5m]) / rate(urcm_process_total[5m])",
          "legendFormat": "Convergence %"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit"},
        "thresholds": {
          "mode": "absolute",
          "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "green", "value": 0.85}]
        }
      },
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 4,
      "title": "Reasoning Latency Distribution",
      "type": "heatmap",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(urcm_reason_latency_seconds_bucket[5m])) by (le)",
          "format": "heatmap"
        }
      ],
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 8}
    },
    {
      "id": 5,
      "title": "Steps per Query",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(urcm_mu_step_total[5m]) / rate(urcm_process_total[5m])",
          "legendFormat": "Avg Steps"
        }
      ],
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}
    },
    {
      "id": 6,
      "title": "Outcome Breakdown",
      "type": "bargauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(urcm_reason_counts_converged[5m])",
          "legendFormat": "Converged"
        },
        {
          "expr": "rate(urcm_reason_counts_dead_end[5m])",
          "legendFormat": "Dead End"
        },
        {
          "expr": "rate(urcm_reason_counts_max_steps[5m])",
          "legendFormat": "Max Steps"
        }
      ],
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "schemaVersion": 38,
  "version": 1
}