# URCM Environment Configuration
# Copy this file to .env and fill in values.
# All variables are optional; defaults are shown in parentheses.

# --- Server ---
URCM_METRICS_BIND=127.0.0.1          # Bind address (127.0.0.1)
URCM_METRICS_PORT=8008                # API port (8008)
URCM_ENV=                             # Environment name (empty)
URCM_CORS_ORIGINS=*                   # Comma-separated CORS origins (*)
URCM_RATE_LIMIT=100                   # Requests per minute (100)

# --- Authentication ---
URCM_METRICS_TOKEN=                   # Bearer token for /metrics, /health, /api/* (empty = no auth)
URCM_ADMIN_KEY=                       # Admin key for kernel unlock (empty = disabled)

# --- SLO Thresholds ---
URCM_SLO_MIN_FINAL_MU=0.4            # Minimum acceptable final mu (0.4)
URCM_SLO_MAX_STEPS_RATE=0.5          # Maximum fraction of max-steps runs (0.5)

# --- Logging ---
URCM_LOG_MAX_BYTES=5000000            # Max log file size before rotation (5MB)
URCM_LOG_BACKUPS=5                    # Number of rotated log files to keep (5)
URCM_RUN_ID=                          # Run identifier for log correlation (empty)
